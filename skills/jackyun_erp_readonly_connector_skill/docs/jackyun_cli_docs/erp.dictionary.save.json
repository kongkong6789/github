{
    "method": "erp.dictionary.save",
    "summary": "新增数据字典",
    "description": "新增数据字典",
    "request": {
        "contentType": "application/json",
        "schema": {
            "type": "object",
            "properties": {
                "dictValue": {
                    "type": "string",
                    "example": "尺码",
                    "description": "字典名（对应左侧的字典项 如 成分）"
                },
                "orderIndex": {
                    "type": "integer",
                    "example": 1,
                    "description": "序号"
                },
                "text": {
                    "type": "string",
                    "example": "2XL",
                    "description": "名称"
                },
                "value": {
                    "type": "string",
                    "example": "0034",
                    "description": "编号"
                }
            }
        },
        "example": {
            "dictValue": "尺码",
            "orderIndex": 1,
            "text": "2XL",
            "value": "0034"
        }
    },
    "response": {
        "contentType": "application/json",
        "schema": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer",
                    "example": 200
                },
                "msg": {
                    "type": "string",
                    "example": ""
                },
                "result": {
                    "type": "object",
                    "properties": {
                        "data": {
                            "type": "object",
                            "properties": {}
                        },
                        "contextId": {
                            "type": "string",
                            "example": "1923146932470613760"
                        }
                    }
                },
                "subCode": {
                    "type": "string",
                    "example": ""
                }
            }
        },
        "example": {
            "code": 200,
            "msg": "",
            "result": {
                "data": {},
                "contextId": "1923146932470613760"
            },
            "subCode": ""
        }
    }
}