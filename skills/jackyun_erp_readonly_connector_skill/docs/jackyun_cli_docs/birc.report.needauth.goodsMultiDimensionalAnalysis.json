{
    "method": "birc.report.needauth.goodsMultiDimensionalAnalysis",
    "summary": "货品销售多维分析报表",
    "description": "货品销售多维分析报表查询接口",
    "request": {
        "contentType": "application/json",
        "schema": {
            "type": "object",
            "properties": {
                "finReceiptStatus": {
                    "type": "string",
                    "example": "0,1",
                    "description": "收款状态，查询多个使用英文逗号分隔，不传默认全部。0：未收款，1：已收款，2：部分收款"
                },
                "startFinReceiptTime": {
                    "type": "string",
                    "example": "2024-07-01",
                    "description": "收款开始时间"
                },
                "timeType": {
                    "type": "integer",
                    "example": 3,
                    "description": "统计时间。2：按月统计，3：按日统计"
                },
                "pageSize": {
                    "type": "integer",
                    "example": 50,
                    "description": "每页条数"
                },
                "skuIds": {
                    "type": "string",
                    "example": "1980498431363023616,1972522435990847744,1965473105817764353",
                    "description": "规格id，查询多个使用英文逗号分隔，不传默认全部"
                },
                "endFinReceiptTime": {
                    "type": "string",
                    "example": "2024-07-01",
                    "description": "收款结束时间"
                },
                "tradeFrom": {
                    "type": "string",
                    "example": "0,6",
                    "description": "订单来源。查询多个使用英文逗号分隔，不传默认全部。0：其他，6：售后"
                },
                "logisticIds": {
                    "type": "string",
                    "example": "982368299883299584,981841120540230400,981787574520251136",
                    "description": "物流公司id。查询多个使用英文逗号分隔，不传默认全部。"
                },
                "filterTimeType": {
                    "type": "integer",
                    "example": 2,
                    "description": "统计时间类型。1：下单时间，2：发货时间，3：付款时间"
                },
                "summaryType": {
                    "type": "string",
                    "example": "channel,goods",
                    "description": "汇总维度。常用值：time,channel,brand,cate,country,province,city,goods,sku,channelCate,warehouse,logistic,seller,finReceiptTime,company,depart。多个维度使用英文逗号分隔"
                },
                "pageIndex": {
                    "type": "integer",
                    "example": 0,
                    "description": "分页页码，从0开始"
                },
                "shopIds": {
                    "type": "string",
                    "example": "1498402603019928448,1287124464992715136",
                    "description": "销售渠道id，查询多个使用英文逗号分隔，不传默认全部"
                },
                "tradeStatus": {
                    "type": "string",
                    "example": "0,6000",
                    "description": "订单状态。查询多个使用英文逗号分隔，不传默认全部。0：未发货，4040：部分发货，6000：已发货"
                },
                "departId": {
                    "type": "string",
                    "example": "1915165648533193344,1931369377171112704,1981938700547326592",
                    "description": "部门id，查询多个使用英文逗号分隔，不传默认全部"
                },
                "startTime": {
                    "type": "string",
                    "example": "2024-07",
                    "description": "统计开始时间。timeType=2 时格式 yyyy-MM；timeType=3 时格式 yyyy-MM-dd"
                },
                "sellerIds": {
                    "type": "string",
                    "example": "1945702957593691776,1153451354635403776",
                    "description": "业务员id，查询多个使用英文逗号分隔，不传默认全部"
                },
                "warehouseIds": {
                    "type": "string",
                    "example": "1690670461930669184,1690665141229552768",
                    "description": "仓库id，查询多个使用英文逗号分隔，不传默认全部"
                },
                "endTime": {
                    "type": "string",
                    "example": "2024-07",
                    "description": "统计结束时间。timeType=2 时格式 yyyy-MM；timeType=3 时格式 yyyy-MM-dd"
                },
                "tradeType": {
                    "type": "string",
                    "example": "7,8,11,12",
                    "description": "订单类型。查询多个使用英文逗号分隔，不传默认全部。1:零售业务,2:代发货(来自分销商),3:预售订单,4:周期性订购,5:代销售(供货商发货),6:现款现货,7:售后发货,8:售后退货,9:批发业务(B2B),10:试销业务,11:错漏调整,12:仅退款,13:销售返利,91:自定义1,92:自定义2,93:自定义3...100:自定义10"
                },
                "assemblyDimension": {
                    "type": "integer",
                    "example": 0,
                    "description": "组合装统计维度，0：按组合装，1：按单品"
                }
            }
        },
        "example": {
            "finReceiptStatus": "0,1",
            "startFinReceiptTime": "2024-07-01",
            "timeType": 3,
            "pageSize": 50,
            "skuIds": "1980498431363023616,1972522435990847744,1965473105817764353",
            "endFinReceiptTime": "2024-07-01",
            "tradeFrom": "0,6",
            "logisticIds": "982368299883299584,981841120540230400,981787574520251136",
            "filterTimeType": 2,
            "summaryType": "channel,goods",
            "pageIndex": 0,
            "shopIds": "1498402603019928448,1287124464992715136",
            "tradeStatus": "0,6000",
            "departId": "1915165648533193344,1931369377171112704,1981938700547326592",
            "startTime": "2024-07",
            "sellerIds": "1945702957593691776,1153451354635403776",
            "warehouseIds": "1690670461930669184,1690665141229552768",
            "endTime": "2024-07",
            "tradeType": "7,8,11,12",
            "assemblyDimension": 0
        }
    },
