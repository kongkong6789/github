# Copy this file to .env. P13 doctor treats the first three keys as required
# for real LLM runs; secret values are reported only as set/not set.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional path overrides. Blank values use repo-local defaults.
A2A_RAW_DIR=
A2A_DATA_DIR=
A2A_WIKI_DIR=
A2A_CLEANED_DIR=
A2A_DERIVED_DIR=
A2A_WAREHOUSE_DIR=
A2A_LIGHTRAG_DIR=
A2A_TASK_DIR=
A2A_THREAD_ARCHIVE_DIR=
A2A_DUCKDB_PATH=
A2A_CONNECTOR_REGISTRY=
A2A_MCP_POLICY_PATH=
A2A_SKILL_REGISTRY_DIR=
A2A_AGENT_TEMPLATE_DIR=
A2A_AUDIT_LOG=
A2A_JACKYUN_SKILL_DIR=
JACKYUN_APP_KEY=
JACKYUN_APP_SECRET=
JACKYUN_API_URL=https://open.jackyun.com/open/openapi/do
A2A_KINGDEE_SKILL_DIR=
KINGDEE_BASE_URL=
KINGDEE_ACCT_ID=
KINGDEE_USERNAME=
KINGDEE_PASSWORD=
KINGDEE_LCID=2052

# Optional WeCom / 企业微信智能表 read-only source.
# Use WeDoc MCP for smart-sheet reads; webhook/API writes stay outside default Agent permissions.
# Runtime prompts can pass a doc.weixin.qq.com/smartsheet URL directly; WECOM_SMARTSHEET_MCP_URL is the MCP service URL, not the smart-sheet URL.
# Accepted aliases: WEWORK_SMARTSHEET_MCP_URL, WEDOC_MCP_URL, WEWORK_WEDOC_MCP_URL.
# A2A_WECOM_SMARTSHEET_SOURCE_CONFIG can stay blank. config/wecom_smartsheet_sources.json is optional for reusable named sources only.
# Prefer mcp_url_env in config/wecom_smartsheet_sources.example.json; do not commit inline apikey/scode values.
# WECOM_WEBHOOK_URL is for optional external write-back integrations only; default Agent tools do not call it.
A2A_WECOM_SMARTSHEET_SOURCE_CONFIG=
WECOM_SMARTSHEET_MCP_URL=
WECOM_WEBHOOK_URL=
WEWORK_SMARTSHEET_MCP_URL=
WEDOC_MCP_URL=
WEWORK_WEDOC_MCP_URL=
WECOM_SMARTSHEET_URL=
WECOM_SMARTSHEET_DOCID=
WECOM_SMARTSHEET_SHEET_ID=
WECOM_SMARTSHEET_SHEET_IDS=
WECOM_SMARTSHEET_SOURCE_ID=
WECOM_SMARTSHEET_DATASET=channel_daily_sales

# Optional Supermemory read-only memory context.
# Recall/context/profile are policy-registered as context only, never business evidence.
# save_memory is blocked behind human confirmation and sensitive-field scanning.
SUPERMEMORY_MCP_URL=
SUPERMEMORY_API_KEY=
SUPERMEMORY_CONTAINER_TAG=

# Local service defaults checked by scripts/doctor.py.
A2A_BACKEND_PORT=2024
A2A_FRONTEND_PORT=3000
A2A_DOCTOR_SKIP_PORT_CHECKS=false

# Workbench API protection.
# Localhost same-origin access is allowed in development. Non-local access and production
# should set this key and send it as x-a2a-api-key or Authorization: Bearer <key>.
A2A_WORKBENCH_API_KEY=
A2A_WORKBENCH_REQUIRE_API_KEY=false

# Optional full LightRAG Server integration.
# Keep Obsidian as the source of truth, and let LightRAG index wiki + cleaned CSV.
A2A_LIGHTRAG_MODE=auto
LIGHTRAG_API_URL=http://127.0.0.1:9621
LIGHTRAG_API_KEY=
LIGHTRAG_HOST=127.0.0.1
LIGHTRAG_PORT=9621
WORKING_DIR=
LLM_BINDING=openai
LLM_MODEL=${OPENAI_MODEL}
LLM_BINDING_HOST=${OPENAI_BASE_URL}
LLM_BINDING_API_KEY=${OPENAI_API_KEY}
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_MAX_TOKEN_SIZE=8192
EMBEDDING_SEND_DIM=false
EMBEDDING_USE_BASE64=false
EMBEDDING_BINDING_HOST=https://your-embedding-provider.example/v1
EMBEDDING_BINDING_API_KEY=your_embedding_api_key_here

# P18 reference platform registry (53aihub-style optional sidecars).
# Embedded stack: DuckDB + Karpathy LLM Wiki + LightRAG remain the default local evidence chain.
# Sidecars below are optional; leave blank to use local tools only.
A2A_REFERENCE_PLATFORMS_CONFIG=
RUOYI_AI_API_URL=http://127.0.0.1:26039
RUOYI_AI_API_KEY=
MAXKB_API_URL=http://127.0.0.1:8080
MAXKB_API_KEY=
MIROFISH_API_URL=http://127.0.0.1:5001
MIROFISH_API_KEY=
